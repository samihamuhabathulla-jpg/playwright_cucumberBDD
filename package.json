{
  "name": "playwrightbdd",
  "version": "1.0.0",
  "description": "Playwright BDD Cucumber Framework",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "cucumber-js --require-module ts-node/register",
    "test:qa": "cross-env ENV=qa cucumber-js --require-module ts-node/register",
    "test:dev": "cross-env ENV=dev cucumber-js --require-module ts-node/register",
    "test:prod": "cross-env ENV=prod cucumber-js --require-module ts-node/register",
    "single": "cucumber-js",
    "smoke": "cucumber-js src/test/features --tags @smoke",
    "regression": "cucumber-js src/test/features --tags @regression",
    "parallel": "cucumber-js src/test/features --parallel 2",
    "failed": "cucumber-js @rerun.txt",
    "test:failed": "cucumber-js @rerun.txt",
    "ci": "cucumber-js src/test/features --tags @smoke --format json:reports/report.json",
    "posttest": "npx ts-node src/helper/report.mts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "cross-env": "^10.1.0",
    "csv-parse": "^7.0.1",
    "multiple-cucumber-html-reporter": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "csv-writer": "^1.6.0",
    "dotenv": "^17.4.2",
    "winston": "^3.19.0"
  }
}