{
  "name": "playwrightbdd",
  "version": "1.0.0",
  "description": "Playwright BDD Cucumber Framework",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
  "test": "cucumber-js --require-module ts-node/register",
  "test:qa": "cross-env ENV=qa cucumber-js --require-module ts-node/register",
  "test:dev": "cross-env ENV=dev cucumber-js --require-module ts-node/register",
  "test:prod": "cross-env ENV=prod cucumber-js --require-module ts-node/register",
  "login": "cucumber-js --require-module ts-node/register --tags @login",
  "invalidLogin": "cucumber-js --require-module ts-node/register --tags @InvalidCredentials",
  "register": "cucumber-js --require-module ts-node/register --tags @register",
  "single": "cucumber-js --require-module ts-node/register",
  "smoke": "cucumber-js --require-module ts-node/register --tags @smoke",
  "regression": "cucumber-js --require-module ts-node/register --tags @regression",
  "parallel": "cucumber-js --require-module ts-node/register --parallel 2",
  "failed": "cucumber-js @rerun/rerun.txt",
  "test:failed": "cucumber-js @rerun/rerun.txt",
  "ci": "cucumber-js --require-module ts-node/register --tags @smoke --format json:reports/cucumber-report.json",
  "posttest": "npx ts-node src/utils/report.mts"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "cross-env": "^10.1.0",
    "csv-parse": "^7.0.1",
    "multiple-cucumber-html-reporter": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "csv-writer": "^1.6.0",
    "dotenv": "^17.4.2",
    "winston": "^3.19.0"
  }
}